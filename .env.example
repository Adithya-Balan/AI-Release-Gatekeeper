# ─── Environment Mode ───
# "development" (bypasses CAP payments if keys are missing) or "production" (Strictly enforces CAP)

# ─── CROO Network ───
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# CROO Agent API Keys (from agent.croo.network dashboard)
CROO_ORCHESTRATOR_KEY=croo_sk_...
CROO_REPO_DOCTOR_KEY=croo_sk_...
CROO_SECURITY_SCANNER_KEY=croo_sk_...
CROO_PR_DESCRIBER_KEY=croo_sk_...
CROO_DEPENDENCY_AUDITOR_KEY=croo_sk_...

# CROO Service IDs (from agent dashboard after configuring services)
CROO_REPO_DOCTOR_SERVICE_ID=
CROO_SECURITY_SCANNER_SERVICE_ID=
CROO_PR_DESCRIBER_SERVICE_ID=
CROO_DEPENDENCY_AUDITOR_SERVICE_ID=

# ─── GitHub ───
GITHUB_TOKEN=ghp_...

# ─── LLM (Free Tier: OpenRouter via OpenAI SDK Compatibility) ───
# Get a free key at: https://openrouter.ai/keys
LLM_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=cohere/north-mini-code:free
# ─── Server ───
HOST=0.0.0.0
PORT=8000
